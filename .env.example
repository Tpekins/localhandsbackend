# ==========================================
# BACKEND ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy this file to .env and fill in the actual values
# Do not commit .env to version control

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Environment: development, staging, production
NODE_ENV=development

# Port on which the server will run
PORT=3000

# Application name
APP_NAME=LocalHands

# API prefix for routes
API_PREFIX=api

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL Database Connection String
# Format: postgresql://username:password@host:port/database
# For local development: postgresql://postgres:password@localhost:5432/localhands
# For production: Use Render PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/localhands"

# ==========================================
# JWT AUTHENTICATION CONFIGURATION
# ==========================================
# Secret key for JWT token generation (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiration time
JWT_EXPIRATION=7d

# JWT refresh token expiration time
JWT_REFRESH_EXPIRATION=30d

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins for CORS
# For local development: http://localhost:5173
# For production: https://your-frontend-domain.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ==========================================
# PAYMENT GATEWAY CONFIGURATION
# ==========================================
# Fabshi Payment Gateway Configuration
FABSHI_API_URL=https://api.fabshi.com
FABSHI_API_KEY=your-fabshi-api-key
FABSHI_SECRET_KEY=your-fabshi-secret-key
FABSHI_WEBHOOK_SECRET=your-webhook-secret

# ==========================================
# EMAIL CONFIGURATION (OPTIONAL)
# ==========================================
# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@localhands.com

# ==========================================
# FILE STORAGE CONFIGURATION
# ==========================================
# Maximum file upload size in bytes
MAX_FILE_SIZE=5242880  # 5MB

# Allowed file types for upload
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Cloud storage configuration (if using AWS S3, Cloudinary, etc.)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=localhands-uploads

# ==========================================
# RATE LIMITING CONFIGURATION
# ==========================================
# Rate limit window in minutes
RATE_LIMIT_TTL=15

# Maximum requests per window
RATE_LIMIT_LIMIT=100

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable/disable request logging
LOG_REQUESTS=true

# ==========================================
# SWAGGER API DOCUMENTATION
# ==========================================
# Enable/disable Swagger documentation
SWAGGER_ENABLED=true

# Swagger title and description
SWAGGER_TITLE=LocalHands API
SWAGGER_DESCRIPTION=API documentation for LocalHands platform
SWAGGER_VERSION=1.0

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable/disable registration
ALLOW_REGISTRATION=true

# Enable/disable email notifications
EMAIL_NOTIFICATIONS_ENABLED=true

# Enable/disable auto-approval of reviews
REVIEW_AUTO_APPROVE=false

# Maintenance mode
MAINTENANCE_MODE=false
